# ─────────────────────────────────────────────────────────────
# TuttoNapule — environment variables
# Copy this file to `.env.local` and fill in the real values.
# `.env.local` is git-ignored and must never be committed.
# ─────────────────────────────────────────────────────────────

# --- Shopify Storefront API (server-side) -------------------------------
# Your store domain, e.g. tuttonapule.myshopify.com  (NOT the public domain)
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
# Storefront API PUBLIC access token
# Shopify Admin → Settings → Apps and sales channels → Develop apps →
#   (your app) → API credentials → Storefront API access token
SHOPIFY_STOREFRONT_ACCESS_TOKEN=your-public-storefront-token

# --- Navigation / homepage categories (comma-separated collection HANDLES) ---
# Handles are the URL slugs of your Shopify collections (Search-engine-listing
# field on each collection). Add/remove handles here — no code change needed.
#
# NEXT_PUBLIC_NAV_COLLECTIONS  → the few shown directly in the top nav bar.
# NEXT_PUBLIC_FEATURED_COLLECTIONS → the ones highlighted on the homepage.
# The full list of every collection is fetched live for the "Categorie"
# slide-over, so you do NOT need to list all 5–6 here.
NEXT_PUBLIC_NAV_COLLECTIONS=caffe,pasta-sughi,dolci
NEXT_PUBLIC_FEATURED_COLLECTIONS=caffe,pasta-sughi,dispensa,dolci

# --- SEO -----------------------------------------------------------------
# Canonical public origin (no trailing slash). Used for canonicals,
# Open Graph URLs, sitemap and robots.
NEXT_PUBLIC_SITE_URL=https://www.tuttonapule.co.uk

# --- Analytics (optional) ------------------------------------------------
# Google Tag Manager container ID. Leave UNSET to disable analytics entirely
# (nothing is injected — clean no-op, ideal for local dev).
NEXT_PUBLIC_GTM_ID=
